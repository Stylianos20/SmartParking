<div class="auth-container">
    <div class="auth-card">
        <h2>Passwort vergessen</h2>
        <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
        <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
        <form action="/users/forgot-password" method="POST" class="auth-form">
            <div class="form-group">
                <label>E-Mail-Adresse</label>
                <input type="email" name="email" required placeholder="Ihre registrierte E-Mail">
            </div>
            <button type="submit" class="btn btn-primary btn-block">Link anfordern</button>
        </form>
        <div class="auth-footer"><a href="/users/login">Zurück zum Login</a></div>
    </div>
</div>