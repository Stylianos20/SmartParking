</head>
<body>

<div class="app-shell">
    <aside class="app-sidebar">
        <div class="sidebar-top">
            <div class="logo-box">
                <div class="logo-inner">P</div>
            </div>
        </div>
        <nav class="side-menu">
            <button class="menu-btn active" onclick="nav(event, 'dash')" title="Übersicht">
                <span class="m-icon">🏠</span>
            </button>
            <button class="menu-btn" onclick="nav(event, 'reserve')" title="Reservierungen">
                <span class="m-icon">🎫</span>
            </button>
            <button class="menu-btn" onclick="nav(event, 'vault')" title="Sicherheit">
                <span class="m-icon">🛡️</span>
            </button>
            <button class="menu-btn" onclick="nav(event, 'exit')" title="Abmelden">
            <span class="m-icon">🚪</span>
    </button>
        </nav>
        
    </aside>

    <main class="main-viewport">
        <header class="top-bar">
            <div class="status-indicator">
                <span class="pulse"></span> System Aktiv
            </div>
            <div class="user-meta">
                <span class="time-now" id="liveTime">00:00</span>
                <div class="user-badge"><%= user.firstName[0] %><%= user.lastName[0] %></div>
            </div>
        </header>

        <div class="scroll-container">
            <div id="section-dash" class="tab-pane active">
                <div class="header-block">
                    <h1>Identitäts-Zentrale</h1>
                    <p>Persönliche Daten und aktueller Kontostatus</p>
                </div>

                <div class="complex-grid">
                    <div class="card glass">
                        <div class="card-header">Nutzerprofil</div>
                        <div class="profile-main">
                            <div class="big-avatar"><%= user.firstName[0] %></div>
                            <div class="name-wrap">
                                <h2><%= user.firstName %> <%= user.lastName %></h2>
                                
                            </div>
                        </div>
                        <div class="stat-rows">
                            <div class="s-row">
                                <span>Benutzer-ID</span>
                                <span class="v-code">#<%= user.id ? user.id.substring(0,100).toUpperCase() : 'N/A' %></span>
                            </div>

                            <div class="s-row">
                                <span>Email-Adresse</span>
                                <span><%= user.email %></span>                            
                        </div>

                            <div class="s-row">
                                <span>Dabei seit</span>
                                <span class="v-tag">
                                    <%= user.creationDate ? new Date(user.creationDate).toLocaleDateString('de-DE') : 'Unbekannt' %>
                                </span>
                            </div>

                            <div class="s-row">
                                <span>Account-Sicherheit</span>
                                <span style="color: #238636; font-weight: bold;">✓ Verifiziert</span>
                            </div>
                        </div>
                                            </div>

                    <div class="card dark-card">
                        <div class="card-header">Registriertes Fahrzeug</div>
                        <div class="plate-visual">
                            <div class="eu-strip">D</div>
                            <div class="plate-number"><%= user.vehicleLicense %></div>
                        </div>
                        <p class="plate-hint">Kennzeichenerkennung ist für alle Parkbereiche aktiviert.</p>
                    </div>
                </div>
            </div>

<div id="section-reserve" class="tab-pane">
    <div class="header-block">
        <h1>Aktive Parkvorgänge</h1>
        <p>Hier siehst du, wo dein Auto gerade steht.</p>
    </div>

    <% if (locals.reservations && reservations.length > 0) { %>
                                <div style="display: grid; gap: 20px;">
                                    <% reservations.forEach(res => { %>
                                        <div class="card booking-card neon-border" style="display: flex; justify-content: space-between; align-items: center; padding: 25px; border-left: 5px solid var(--accent); background: rgba(255,255,255,0.02);">
                            <div>
                                <span style="font-size: 10px; color: var(--accent); font-weight: bold; letter-spacing: 1.5px; text-transform: uppercase;">
                                    <%= res.city || 'Unbekannter Ort' %>
                                </span>
                                
                                <h2 style="margin: 5px 0; font-size: 22px; color: #fff;">
                                    <%= res.spotName || 'Parkplatz ' + res.spotId %>
                                </h2>
                                
                                <p style="margin: 0; font-size: 14px; color: #8b949e; margin-bottom: 12px;">
                                    📍 <%= res.street || 'Adresse nicht verfügbar' %>
                                </p>

                                <div style="display: flex; flex-direction: column; gap: 4px;">
                                    <p style="margin: 0; font-size: 13px; color: #c9d1d9; display: flex; align-items: center; gap: 6px;">
                                        <span style="opacity: 0.7;">📅</span> 
                                        Gestartet am <strong><%= new Date(res.startTime).toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' }) %></strong>
                                    </p>
                                    <p style="margin: 0; font-size: 13px; color: #c9d1d9; display: flex; align-items: center; gap: 6px;">
                                        <span class="pulse" style="width: 12px; height: 12px; background: #3fb950; border-radius: 50%; display: inline-block;"></span>
                                           Um <strong><%= new Date(res.startTime).toLocaleTimeString('de-DE', {hour: '2-digit', minute:'2-digit'}) %> Uhr</strong>
                                    </p>
                                </div>
                            </div>

                            <div style="text-align: right;">
                                <div style="margin-bottom: 15px;">
                                    <span style="display: block; font-size: 10px; color: #8b949e; text-transform: uppercase;">Status</span>
                                    <strong style="color: #3fb950;">Aktiv</strong>
                                </div>
                                
                                <button class="action-btn cancel" 
    onclick="openReleaseModal('<%= res.spotId %>', '<%= res.id %>')"
    style="padding: 10px 20px; font-size: 13px; font-weight: bold; cursor: pointer;">
    Parken beenden
</button>
                            </div>
                        </div>
            <% }); %>
        </div>
    <% } else { %>
        <div class="card empty-card" style="text-align: center; padding: 60px 20px; border: 1px dashed #30363d; background: transparent;">
            <div style="font-size: 40px; margin-bottom: 20px;">🚗</div>
            <h3 style="color: #fff; margin-bottom: 10px;">Alles frei!</h3>
            <p style="color: #8b949e; margin-bottom: 30px;">Du hast aktuell keine aktiven Parkvorgänge.</p>
            <a href="/parking" class="action-btn primary" style="text-decoration: none;">Parkplatz finden</a>
        </div>
    <% } %>
</div>

            <div id="section-vault" class="tab-pane">
                <div class="header-block">
                    <h1>Sicherheit & Zugang</h1>
                    <p>Aktualisiere deine Anmeldedaten</p>
                </div>
                <div class="card glass vault-card">
                    <form action="/users/change-password" method="POST" class="smart-form">
                        <div class="input-field">
                            <label>Aktuelles Passwort</label>
                            <input type="password" name="currentPassword" placeholder="Dein bisheriges Passwort" required>
                        </div>
                        <div class="input-field">
                            <label>Neues Passwort</label>
                            <input type="password" name="newPassword" placeholder="Mindestens 6 Zeichen" required>
                        </div>
                        <button type="submit" class="action-btn primary">Zugangsdaten aktualisieren</button>
                    </form>
                </div>
            </div>

            <div id="section-exit" class="tab-pane">
    <div class="header-block">
        <h1>Sitzung beenden</h1>
        <p>Möchtest du dich wirklich vom SmartParking System abmelden?</p>
    </div>

    <div class="complex-grid" style="grid-template-columns: 1fr;">
        <div class="card glass" style="text-align: center; padding: 60px 20px; border: 1px dashed rgba(248, 81, 73, 0.4);">
            <div class="big-avatar" style="margin: 0 auto 25px; background: rgba(248, 81, 73, 0.1); color: #f85149;">
                ✕
            </div>
            <h2 style="color: #fff; margin-bottom: 10px;">Auf Wiedersehen, <%= user.firstName %>!</h2>
            <p style="color: #8b949e; margin-bottom: 30px; max-width: 400px; margin-left: auto; margin-right: auto;">
                Deine aktiven Reservierungen bleiben bestehen. Du kannst dich jederzeit wieder einloggen, um deinen Parkplatz zu verwalten.
            </p>
            
            <div style="display: flex; gap: 15px; justify-content: center;">
                <button class="action-btn" style="background: #30363d; color: #fff;" onclick="nav(event, 'dash')">
                    Doch bleiben
                </button>
                
                <a href="/users/logout" class="action-btn cancel" style="text-decoration: none; display: flex; align-items: center; gap: 8px;">
                    Sicher abmelden
                </a>
            </div>
        </div>
    </div>
</div>
        </div>
    </main>
</div>


<div id="confirmation-modal" class="hidden">
    <div class="bg-[#161b22] border border-[#30363d] rounded-xl shadow-2xl p-6 w-full max-w-sm">
        <h3 class="text-xl font-bold mb-4 text-white">Reservierung beenden</h3>
        <p class="mb-6 text-[#8b949e]">
            Möchten Sie den Parkplatz <span class="font-bold text-[#00f2ff]" id="modal-spot-id"></span> wirklich freigeben?
        </p>
        <div class="flex justify-end space-x-3">
            <button id="close-modal-btn" class="px-4 py-2 bg-[#30363d] text-white rounded-lg hover:bg-gray-700 transition">Abbrechen</button>
            <button id="confirm-release-btn" class="px-4 py-2 bg-red-600 text-white rounded-lg shadow-lg hover:bg-red-700 transition">Jetzt Freigeben</button>
        </div>
    </div>
</div>






<style>
    /* Die Styles bleiben identisch, da sie nur für das Layout zuständig sind */
    :root {
        --accent: #00f2ff;
        --sidebar-w: 80px;
        --bg: #0d1117;
        --card: rgba(22, 27, 34, 0.7);
    }

body { 
    margin: 0; 
    background: var(--bg); 
    color: #c9d1d9; 
    font-family: 'Inter', system-ui; 
    /* ÄNDERUNG: overflow: hidden entfernen oder auf auto setzen */
    overflow-y: auto; 
}

.app-shell { 
    display: flex; 
    /* ÄNDERUNG: min-height statt height nutzen */
    min-height: 100vh; 
}

    .app-sidebar {
        width: var(--sidebar-w); background: #161b22; border-right: 1px solid #30363d;
        display: flex; flex-direction: column; align-items: center; padding: 25px 0;
    }
    .logo-box { width: 45px; height: 45px; background: var(--accent); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 50px; }
    .logo-inner { font-weight: 900; color: #000; font-size: 20px; }
    .side-menu { display: flex; flex-direction: column; gap: 20px; flex: 1; }
    .menu-btn { background: none; border: none; font-size: 20px; padding: 12px; border-radius: 12px; cursor: pointer; transition: 0.3s; color: #8b949e; }
    .menu-btn.active { background: rgba(0, 242, 255, 0.1); color: var(--accent); }
    .logout-btn { text-decoration: none; color: #f85149; font-size: 24px; font-weight: bold; }

    .main-viewport { flex: 1; display: flex; flex-direction: column; position: relative; }
    .top-bar { height: 70px; border-bottom: 1px solid #30363d; display: flex; align-items: center; justify-content: space-between; padding: 0 40px; }
    .status-indicator { display: flex; align-items: center; gap: 10px; font-size: 13px; color: #8b949e; }
    .pulse { width: 8px; height: 8px; background: #238636; border-radius: 50%; box-shadow: 0 0 10px #238636; animation: pulse 2s infinite; }
    .user-badge { width: 35px; height: 35px; background: #30363d; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold; }

.scroll-container { 
    flex: 1; 
    padding: 40px; 
    overflow-y: visible; 
}    .header-block { margin-bottom: 40px; }
    .header-block h1 { margin: 0; font-size: 32px; font-weight: 700; color: #fff; }
    .tab-pane { display: none; }
    .tab-pane.active { display: block; animation: slideIn 0.4s ease-out; }

    .complex-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 30px; }
    .card { background: var(--card); border: 1px solid #30363d; border-radius: 20px; padding: 30px; position: relative; }
    .glass { backdrop-filter: blur(10px); background: rgba(255,255,255,0.03); }
    .card-header { font-size: 12px; color: #8b949e; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 25px; }

    .profile-main { display: flex; align-items: center; gap: 20px; margin-bottom: 30px; }
    .big-avatar { width: 70px; height: 70px; background: linear-gradient(135deg, #00f2ff, #0062ff); border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 30px; color: #000; font-weight: bold; }
    .name-wrap h2 { margin: 0; font-size: 24px; color: #fff; }
    .stat-rows { display: flex; flex-direction: column; gap: 12px; border-top: 1px solid #30363d; padding-top: 20px; }
    .s-row { display: flex; justify-content: space-between; font-size: 14px; }
    .v-tag { color: var(--accent); font-weight: bold; }

    .plate-visual { background: #eee; color: #000; width: 250px; height: 50px; border-radius: 5px; display: flex; border: 2px solid #555; margin: 20px 0; overflow: hidden; }
    .eu-strip { width: 30px; background: #003399; color: white; display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 14px; }
    .plate-number { flex: 1; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: 900; letter-spacing: 2px; }

    .action-btn { border: none; padding: 12px 24px; border-radius: 12px; font-weight: bold; cursor: pointer; transition: 0.3s; }
    .action-btn.primary { background: var(--accent); color: #000; text-decoration: none; display: inline-block; }
    .action-btn.primary:hover { transform: scale(1.05); box-shadow: 0 0 20px rgba(0, 242, 255, 0.4); }
    .action-btn.cancel { background: rgba(248, 81, 73, 0.1); color: #f85149; border: 1px solid #f85149; }

    /* Formular Styles */
    .smart-form .input-field { margin-bottom: 20px; }
    .smart-form label { display: block; font-size: 13px; color: #8b949e; margin-bottom: 8px; }
    .smart-form input { width: 100%; padding: 12px; background: #0d1117; border: 1px solid #30363d; border-radius: 8px; color: #fff; box-sizing: border-box; }

    

    @keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.5; } 100% { opacity: 1; } }
    @keyframes slideIn { from { opacity: 0; transform: translateX(20px); } to { opacity: 1; transform: translateX(0); } }

    /* MODAL FIX - Jetzt mit sichtbarem Hintergrund */
    #confirmation-modal.hidden { 
        display: none !important; 
    }

    #confirmation-modal { 
        display: flex; 
        position: fixed; 
        inset: 0; /* Deckt alles ab von Top 0 bis Bottom 0 */
        background-color: rgba(0, 0, 0, 0.85); /* Dunkler, halbtransparenter Hintergrund */
        z-index: 9999;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(4px); /* Macht den Hintergrund schick verschwommen */
    }

    /* Damit das Modal-Fenster selbst stabil bleibt */
    #confirmation-modal > div {
        position: relative;
        z-index: 10000;
    }
</style>


<script>
    function nav(event, target) {
        document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.menu-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('section-' + target).classList.add('active');
        event.currentTarget.classList.add('active');
    }

    setInterval(() => {
        const now = new Date();
        document.getElementById('liveTime').innerText = now.getHours().toString().padStart(2, '0') + ":" + now.getMinutes().toString().padStart(2, '0');
    }, 1000);

    let currentSpotId = null;
let currentReservationId = null; // Neue Variable

const modal = document.getElementById('confirmation-modal');

// Funktion nimmt jetzt zwei Argumente an
window.openReleaseModal = function(spotId, reservationId) {
    currentSpotId = spotId;
    currentReservationId = reservationId; // Speichern
    
    document.getElementById('modal-spot-id').innerText = spotId;
    modal.classList.remove('hidden');
};

document.getElementById('confirm-release-btn').onclick = async function() {
    try {
        const response = await fetch('/parking/api/release', { 
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ 
                spotId: currentSpotId,
                reservationId: currentReservationId // Jetzt mitschicken!
            })
        });

        if (response.ok) {
            window.location.reload();
        } else {
            const errorData = await response.json();
            alert("Fehler: " + (errorData.message || "Unbekannter Fehler"));
        }
    } catch (err) {
        alert("Netzwerkfehler.");
    }
};
</script>
</body>
</html>