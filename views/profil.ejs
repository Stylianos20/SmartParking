</head>
<link rel="stylesheet" href="/stylesheets/profil.css">
<body>

<div class="app-shell">
    <aside class="app-sidebar">
        <div class="sidebar-top">
            <div class="logo-box">
                <div class="logo-inner">P</div>
            </div>
        </div>
        <nav class="side-menu">
            <button class="menu-btn active" onclick="nav(event, 'dash')" title="Übersicht">
                <span class="m-icon">🏠</span>
            </button>
            <button class="menu-btn" onclick="nav(event, 'reserve')" title="Reservierungen">
                <span class="m-icon">🎫</span>
            </button>
            <button class="menu-btn" onclick="nav(event, 'vault')" title="Sicherheit">
                <span class="m-icon">🛡️</span>
            </button>
            <button class="menu-btn" onclick="nav(event, 'Kennzeichenerkennung')" title="Kennzeichen Simulation">
                <span class="m-icon">🚗</span>
            </button>
            <button class="menu-btn" onclick="nav(event, 'exit')" title="Abmelden">
            <span class="m-icon">🚪</span>
    </button>
        </nav>
        
    </aside>

    <main class="main-viewport">
        <header class="top-bar">
            <div class="status-indicator">
                <span class="pulse"></span> System Aktiv
            </div>
            <div class="user-meta">
                <span class="time-now" id="liveTime">00:00</span>
                <div class="user-badge"><%= user.firstName[0] %><%= user.lastName[0] %></div>
            </div>
        </header>

        <div class="scroll-container">
            <div id="section-dash" class="tab-pane active">
                <div class="header-block">
                    <h1>Identitäts-Zentrale</h1>
                    <p>Persönliche Daten und aktueller Kontostatus</p>
                </div>

                <div class="complex-grid">
                    <div class="card glass">
                        <div class="card-header">Nutzerprofil</div>
                        <div class="profile-main">
                            <div class="big-avatar"><%= user.firstName[0] %></div>
                            <div class="name-wrap">
                                <h2><%= user.firstName %> <%= user.lastName %></h2>
                                
                            </div>
                        </div>
                        <div class="stat-rows">
                            <div class="s-row">
                                <span>Benutzer-ID</span>
                                <span class="v-code">#<%= user.id ? user.id.substring(0,100).toUpperCase() : 'N/A' %></span>
                            </div>

                            <div class="s-row">
                                <span>Email-Adresse</span>
                                <span><%= user.email %></span>                            
                        </div>

                            <div class="s-row">
                                <span>Dabei seit</span>
                                <span class="v-tag">
                                    <%= user.creationDate ? new Date(user.creationDate).toLocaleDateString('de-DE') : 'Unbekannt' %>
                                </span>
                            </div>

                            <div class="s-row">
                                <span>Account-Sicherheit</span>
                                <span style="color: #238636; font-weight: bold;">✓ Verifiziert</span>
                            </div>
                        </div>
                                            </div>

                    <div class="card dark-card">
                        <div class="card-header">Registriertes Fahrzeug</div>
                        <div class="plate-visual">
                            <div class="eu-strip">D</div>
                            <div class="plate-number"><%= user.vehicleLicense %></div>
                        </div>
                        <p class="plate-hint">Kennzeichenerkennung ist für alle Parkbereiche aktiviert.</p>
                    </div>
                </div>
            </div>

    <div id="section-reserve" class="tab-pane">
    <div class="header-block">
        <h1>Park-Historie & Reservierungen</h1>
        <p>Verwalte deine aktiven und vergangenen Parkvorgänge.</p>
        
        <div class="filter-bar" style="margin-top: 20px; display: flex; gap: 10px;">
            <button class="filter-btn" onclick="filterReservations('all')">Alle</button>
            <button class="filter-btn active" onclick="filterReservations('active')">Aktiv</button>
            <button class="filter-btn" onclick="filterReservations('completed')">Abgeschlossen</button>
            <button class="filter-btn" onclick="filterReservations('cancelled')">Storniert</button>
        </div>
    </div>
    
    <div id="reservations-list" style="display: grid; gap: 20px;">
    <% if (locals.reservations && reservations.length > 0) { %>
        <% reservations.forEach(res => { 
            const s = (res.status || 'active').toLowerCase().trim();    
            let statusColor = '#3fb950'; 
            let statusText = 'Aktiv';
            
            if (s === 'completed') { 
                statusColor = '#e3b341'; 
                statusText = 'Abgeschlossen'; 
            } else if (s === 'cancelled') { 
                statusColor = '#f85149'; 
                statusText = 'Storniert'; 
            } else if (s === 'booked') {
                statusColor = '#58a6ff';
                statusText = 'Reserviert';
            }
        %>
            <div class="card booking-card reservation-item" 
                 data-status="<%= s %>" 
                 style="display: flex; justify-content: space-between; align-items: center; padding: 25px; border-left: 5px solid <%= statusColor %>; background: rgba(255,255,255,0.02);">
                
                <div>
                    <span style="font-size: 10px; color: <%= statusColor %>; font-weight: bold; letter-spacing: 1.5px; text-transform: uppercase;">
                        <%= res.stadt || 'SmartParking System' %>
                    </span>
                    <h2 style="margin: 5px 0; font-size: 22px; color: #fff;">
                        <%= res.spotName || 'Platz ' + res.spotId %>
                    </h2>
                    <p style="margin: 0; font-size: 14px; color: #8b949e; margin-bottom: 12px;">
                        📍 <%= res.street || 'Parkhaus-Sektor ' + res.spotId %>
                    </p>

                    <div style="display: flex; flex-direction: column; gap: 4px;">
                        <p style="margin: 0; font-size: 13px; color: #c9d1d9; display: flex; align-items: center; gap: 6px;">
                            <span style="opacity: 0.7;">📅</span> 
                            <%= (s === 'active' || s === 'completed') ? 'Einfahrt am' : 'Reserviert am' %> 
                            <strong><%= new Date(res.startTime).toLocaleDateString('de-DE') %></strong>
                        </p>
                        <% if (res.entryTime) { %>
                            <p style="margin: 0; font-size: 13px; color: #3fb950; display: flex; align-items: center; gap: 6px;">
                                <span>🚗</span> Einfahrt: <strong><%= new Date(res.entryTime).toLocaleTimeString('de-DE', {hour: '2-digit', minute:'2-digit'}) %> Uhr</strong>
                            </p>
                        <% } %>
                        <% if (s === 'completed' && res.exitTime) { %>
                            <p style="margin:0; font-size: 13px; color: #f85149; display: flex; align-items: center; gap: 6px;">
                                <span>🏁</span> Ausfahrt: <strong><%= new Date(res.exitTime).toLocaleTimeString('de-DE', {hour: '2-digit', minute:'2-digit'}) %> Uhr</strong>
                            </p>
                        <% } %>
                    </div>
                </div>

                <div style="text-align: right;">
                    <div style="margin-bottom: 15px;">
                        <span style="display: block; font-size: 14px; color: #8b949e; text-transform: uppercase;">Status</span>
                        <strong style="color: <%= statusColor %>;"><%= statusText %></strong>
                    </div>
                    
                    <% if ((s === 'active' || s === 'booked') && !res.entryTime) { %>
                        <button class="action-btn cancel" 
                            onclick="openReleaseModal('<%= res.spotId %>', '<%= res.id %>')"
                            style="padding: 10px 20px; font-size: 13px; font-weight: bold; cursor: pointer;">
                            Stornieren
                        </button>
                    <% } %>

                    <% if (s === 'completed') { %>
    <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 10px;">
        <div style="text-align: right;">
            <span style="font-weight: bold; color: #ffffff; font-size: 20px;">
                <%= (res.totalPrice || 0).toFixed(2) %>€
            </span>
            <br>
            <span style="color: #8b949e; font-size: 12px;">
                Dauer: <%= Math.floor((new Date(res.exitTime) - new Date(res.entryTime)) / 60000) %> Min.
            </span>
        </div>
        
        <a href="/parking/invoice/<%= res.id %>" 
           class="action-btn" 
           style="background: #30363d; color: #58a6ff; border: 1px solid #388bfd; padding: 5px 12px; font-size: 11px; text-decoration: none; border-radius: 6px; display: flex; align-items: center; gap: 5px;">
            <span>📄</span> Rechnung PDF
        </a>
    </div>
<% } %>
                </div>
            </div>
        <% }); %> <% } else { %>
        <div class="card empty-card" style="text-align: center; padding: 60px 20px; border: 1px dashed #30363d; background: transparent;">
            <div style="font-size: 40px; margin-bottom: 20px;">🚗</div>
            <h3 style="color: #fff; margin-bottom: 10px;">Alles frei!</h3>
            <p style="color: #8b949e; margin-bottom: 30px;">Du hast aktuell keine Parkvorgänge.</p>
            <a href="/parking" class="action-btn primary" style="text-decoration: none;">Parkplatz finden</a>
        </div>
    <% } %>
</div>
            </div>
            <div id="section-vault" class="tab-pane">
                <div class="header-block">
                    <h1>Sicherheit & Zugang</h1>
                    <p>Aktualisiere deine Anmeldedaten</p>
                </div>
                <div class="card glass vault-card">
                    <form action="/users/change-password" method="POST" class="smart-form">
                        <div class="input-field">
                            <label>Aktuelles Passwort</label>
                            <input type="password" name="currentPassword" placeholder="Dein bisheriges Passwort" required>
                        </div>
                        <div class="input-field">
                            <label>Neues Passwort</label>
                            <input type="password" name="newPassword" placeholder="Mindestens 6 Zeichen" required>
                        </div>
                        <button type="submit" class="action-btn primary">Zugangsdaten aktualisieren</button>
                    </form>
                </div>
            </div>

    <div id="section-exit" class="tab-pane">
    <div class="header-block">
        <h1>Sitzung beenden</h1>
        <p>Möchtest du dich wirklich vom SmartParking System abmelden?</p>
    </div>

    <div class="complex-grid" style="grid-template-columns: 1fr;">
        <div class="card glass" style="text-align: center; padding: 60px 20px; border: 1px dashed rgba(248, 81, 73, 0.4);">
            <div class="big-avatar" style="margin: 0 auto 25px; background: rgba(248, 81, 73, 0.1); color: #f85149;">✕</div>
            <h2 style="color: #fff; margin-bottom: 10px;">Auf Wiedersehen, <%= user.firstName %>!</h2>
            <p style="color: #8b949e; margin-bottom: 30px; max-width: 400px; margin-left: auto; margin-right: auto;">
                Deine aktiven Reservierungen bleiben bestehen.
            </p>
            <div style="display: flex; gap: 15px; justify-content: center;">
                <button class="action-btn" style="background: #30363d; color: #fff;" onclick="nav(event, 'dash')">Doch bleiben</button>
                <a href="/users/logout" class="action-btn cancel" style="text-decoration: none;">Sicher abmelden</a>
            </div>
        </div>
    </div>
</div>
<div id="section-Kennzeichenerkennung" class="tab-pane">
    <div class="header-block">
        <h1>🛡️ SmartParking Control Tower</h1>
        <p>Simuliere die Hardware-Schranken des Parkhauses</p>
    </div>
    
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="card" style="border: 2px solid #238636; background: rgba(35, 134, 54, 0.05);">
            <h2 style="color: #3fb950; margin-top: 0;">📥 Einfahrt</h2>
            <input type="text" id="entryPlate" placeholder="KENNZEICHEN..." style="width: 100%; padding: 12px; margin-bottom: 10px; border-radius: 8px; border: 1px solid #30363d; background: #0d1117; color: white; font-family: monospace; font-size: 18px; text-transform: uppercase;">
            
            <select id="entrySpotSelect" style="width: 100%; padding: 10px; margin-bottom: 15px; border-radius: 8px; border: 1px solid #30363d; background: #161b22; color: #8b949e;">
                <option value="">-- Zuerst Kennzeichen prüfen --</option>
            </select>

            <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 10px;">
                <button onclick="fetchMySpots('entry')" class="action-btn" style="background: #30363d; border: 1px solid #8b949e;">PRÜFEN</button>
                <button onclick="handleGate('entry')" class="action-btn primary" style="background: #238636;">Schranke ÖFFNEN</button>
            </div>
        </div>

        <div class="card" style="border: 2px solid #f85149; background: rgba(248, 81, 73, 0.05);">
            <h2 style="color: #f85149; margin-top: 0;">📤 Ausfahrt</h2>
            <input type="text" id="exitPlate" placeholder="KENNZEICHEN..." style="width: 100%; padding: 12px; margin-bottom: 10px; border-radius: 8px; border: 1px solid #30363d; background: #0d1117; color: white; font-family: monospace; font-size: 18px; text-transform: uppercase;">
            
            <select id="exitSpotSelect" style="width: 100%; padding: 10px; margin-bottom: 15px; border-radius: 8px; border: 1px solid #30363d; background: #161b22; color: #8b949e;">
                <option value="">-- Zuerst Kennzeichen prüfen --</option>
            </select>

            <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 10px;">
                <button onclick="fetchMySpots('exit')" class="action-btn" style="background: #30363d; border: 1px solid #8b949e;">PRÜFEN</button>
                <button onclick="handleGate('exit')" class="action-btn cancel" style="border-color: #f85149; color: #f85149;">AUSFAHRT & ABRECHNUNG</button>
            </div>
        </div>
    </div>
    
    <div id="gateStatus" style="margin-top: 30px; padding: 20px; border-radius: 12px; display: none; border: 1px solid #30363d; background: #161b22;"></div>
        </div>
        </div>
    </main>
</div>


<div id="confirmation-modal" class="hidden">
    <div class="bg-[#161b22] border border-[#30363d] rounded-xl shadow-2xl p-6 w-full max-w-sm">
        <h3 class="text-xl font-bold mb-4 text-white">Reservierung beenden</h3>
        <p class="mb-6 text-[#8b949e]">
            Möchten Sie den Parkplatz <span class="font-bold text-[#00f2ff]" id="modal-spot-id"></span> wirklich freigeben?
        </p>
        <div class="flex justify-end space-x-3">
            <button id="close-modal-btn" class="px-4 py-2 bg-[#30363d] text-white rounded-lg hover:bg-gray-700 transition">Abbrechen</button>
            <button id="confirm-release-btn" class="px-4 py-2 bg-red-600 text-white rounded-lg shadow-lg hover:bg-red-700 transition">Jetzt Freigeben</button>
        </div>
    </div>
</div>

<script type="module" src="/javascripts/profil.js"></script>

</body>
</html>