<div class="auth-container">
    <div class="auth-card">
        <h2>Neues Passwort festlegen</h2>
        <p>Bitte geben Sie Ihr neues Passwort ein.</p>

        <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

<form action="/users/reset-password/<%= token %>" method="POST" class="auth-form">            
    <div class="form-group">
                <label>Neues Passwort</label>
                <input type="password" name="password" required minlength="6" placeholder="Mind. 6 Zeichen">
            </div>
            <div class="form-group">
                <label>Passwort bestätigen</label>
                <input type="password" name="confirmPassword" required placeholder="Passwort wiederholen">
            </div>
            <button type="submit" class="btn btn-primary btn-block">Passwort speichern</button>
        </form>
    </div>
</div>