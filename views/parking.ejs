<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartParking: Parkplatz-Übersicht</title>
    <script src="https://cdn.tailwindcss.com"></script>

    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <style>
        /* ... Ihre Styles ... */
        .btn-primary {
            background-color: #2563eb;
            color: white;
            padding: 0.5rem 1rem;
            border-radius: 0.375rem;
            transition: background-color 0.15s;
        }
        .btn-primary:hover {
            background-color: #1d4ed8;
        }
        .btn-disabled {
            background-color: #9ca3af;
            color: #4b5563;
            padding: 0.5rem 1rem;
            border-radius: 0.375rem;
        }
        #mapid {
            height: 400px;
            border-radius: 0.5rem;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1),
                         0 4px 6px -3px rgba(0, 0, 0, 0.05);
        }
    </style>
</head>
<body class="min-h-screen p-4 sm:p-8">

    <div class="max-w-4xl mx-auto">
        <header class="mb-8 text-center sm:text-left">
            <h1 class="text-3xl sm:text-4xl font-extrabold text-gray-900 mb-2">SmartParking App</h1>
<p class="text-gray-600">Willkommen, <span class="font-bold text-blue-600"><%= user ? user.firstName : 'Gast' %></span>! Finden und reservieren Sie Ihren Parkplatz.</p>        </header>
        <div class="mb-8">
            <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-4">Standort-Übersicht</h2>
            <div class="flex space-x-4 mb-4">
    <button onclick="setParkingFilters({free:true, paid:true})" class="btn-primary">Alle</button>
    <button onclick="setParkingFilters({free:true, paid:false})" class="btn-primary">Kostenlos</button>
    <button onclick="setParkingFilters({free:false, paid:true})" class="btn-primary">Kostenpflichtig</button>
                </div>
            <div id="mapid"></div>
        </div>


        <div id="parking-details" class="hidden bg-blue-50 p-6 sm:p-8 rounded-xl shadow-2xl border border-blue-200 mb-8">
            <div class="flex justify-between items-start">
                <h2 id="detail-title" class="text-xl sm:text-2xl font-bold text-blue-800">Parkplatz Details</h2>
                <button id="close-details-btn" class="text-blue-500 hover:text-blue-700 font-bold text-2xl leading-none">&times;</button>
            </div>
            <div id="detail-content" class="mt-4 text-gray-700 space-y-2">
            </div>
        </div>
        <div class="bg-white p-6 sm:p-8 rounded-xl shadow-2xl border border-gray-100">
            <h2 class="text-xl sm:text-2xl font-bold text-gray-800 mb-2">Aktuelle Parkplatz-Liste</h2>
            <p class="text-gray-500 mb-6">Wählen Sie Ihren Standort und reservieren Sie einen freien Parkplatz sofort.</p>

            <div id="status-message" class="hidden px-4 py-3 rounded relative mb-4" role="alert">
                <strong class="font-bold" id="status-title"></strong>
                <span id="status-text" class="block sm:inline"></span>
            </div>

            <div id="loading" class="text-center text-blue-600 py-12">
                <svg class="animate-spin h-8 w-8 text-blue-600 mx-auto mb-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                Daten werden geladen...
            </div>
            
            <div id="error-message" class="hidden bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4" role="alert">
                <strong class="font-bold">Fehler:</strong>
                <span id="error-text" class="block sm:inline">Konnte Parkplatzdaten nicht laden.</span>
            </div>
            
            <div id="parking-list" class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>

            <div id="no-spots-message" class="hidden text-center py-12 text-gray-500 italic border-t mt-6">
                Derzeit sind keine Parkplätze verfügbar. Versuchen Sie es später erneut.
            </div>
        </div>
    </div>

    <script>
        window.__expressUserId = <%- JSON.stringify(user ? user.id : null) %>;
        window.__isLoggedIn = <%- JSON.stringify(!!user) %>;
    </script>


    <script src="/javascripts/JSparking.js" type="module"></script>
</body>
</html>