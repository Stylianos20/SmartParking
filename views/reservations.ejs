<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
 body {
    font-family: 'Inter', sans-serif;
    background-color: #f7f9fb;
    color: #333;
 }
    </style>
</head>
<body class="p-4 md:p-8">

    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-extrabold text-gray-900 mb-2">Meine gesamte Parkhistorie</h1>
        <p class="text-gray-500 mb-6">Eine Übersicht aller aktiven und abgeschlossenen Reservierungen.</p>

        <div id="message-container" class="mb-4"></div>

        <% if (locals.error) { %>
        <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded-lg shadow-md mb-6" role="alert">
            <p class="font-bold">Fehler beim Laden</p>
            <p><%= error %></p>
        </div>
        <% } %>

        <!-- data-reservations enthält die serverseitigen Daten als JSON-string -->
        <div id="reservations-list" class="mt-5 flex flex-col gap-4"
             data-reservations='<%- JSON.stringify(reservations || []) %>'>
        </div>

        <div id="empty-state" class="hidden mt-5">
            <div class="bg-blue-50 border-l-4 border-blue-400 text-blue-800 p-4 rounded-lg shadow-md" role="alert">
                <p class="font-bold">Keine Historie gefunden</p>
                <p>Sie haben derzeit keine Parkreservierungen in Ihrer Historie.</p>
            </div>
            <a href="/parking" class="inline-block mt-4 px-6 py-2 bg-indigo-600 text-white font-semibold rounded-xl shadow-md hover:bg-indigo-700 transition duration-150">
                Parkplatz reservieren
            </a>
        </div>
    </div>

    <div id="confirmation-modal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden items-center justify-center p-4 z-50">
        <div class="bg-white rounded-xl shadow-2xl p-6 w-full max-w-sm">
            <h3 class="text-xl font-bold mb-4">Reservierung stornieren</h3>
            <p id="modal-text" class="mb-6 text-gray-700">Sind Sie sicher, dass Sie die Reservierung für Parkplatz <span class="font-semibold" id="modal-spot-id"></span> freigeben möchten?</p>
            <div class="flex justify-end space-x-3">
                <button id="cancel-btn" class="px-4 py-2 bg-gray-200 text-gray-800 font-medium rounded-lg hover:bg-gray-300 transition duration-150">Abbrechen</button>
                <button id="confirm-release-btn" class="px-4 py-2 bg-red-600 text-white font-medium rounded-lg hover:bg-red-700 transition duration-150 shadow-md">Freigeben</button>
            </div>
        </div>
    </div>

    <!-- Externes Skript laden -->
<script type="module" src="/javascripts/JSreservation.js"></script>
</body>
</html>
